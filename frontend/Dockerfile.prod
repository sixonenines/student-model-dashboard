FROM node:20-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ENV VITE_BASE_PATH=/studentmodelsdashboard/
ENV VITE_PYTHON_API_BASE=/studentmodelsdashboardbackendpython/api
ENV VITE_R_API_BASE=/studentmodelsdashboardbackendrscript/api

RUN npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.prod.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
